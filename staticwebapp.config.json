{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/_next/static/*", "/images/*", "/*.{png,svg,ico,css,js}"]
  },
  "routes": [
    {
      "route": "/",
      "headers": { "Cache-Control": "no-cache" }
    },
    {
      "route": "/build",
      "rewrite": "/build/index.html",
      "headers": { "Cache-Control": "no-cache" }
    },
    {
      "route": "/build/",
      "rewrite": "/build/index.html",
      "headers": { "Cache-Control": "no-cache" }
    },
    {
      "route": "/t",
      "rewrite": "/t/index.html",
      "headers": { "Cache-Control": "no-cache" }
    },
    {
      "route": "/t/",
      "rewrite": "/t/index.html",
      "headers": { "Cache-Control": "no-cache" }
    },
    {
      "route": "/_next/static/*",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    {
      "route": "/images/*",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    }
  ],
  "mimeTypes": {
    ".json": "application/json"
  }
}
